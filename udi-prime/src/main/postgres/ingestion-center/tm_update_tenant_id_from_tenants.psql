/* Step 2. Analyze all tables after bulk update to use the new index efficiently.*/
ANALYZE techbd_udi_ingress.dashboard_widget_metadata;
ANALYZE techbd_udi_ingress.sat_csv_fhir_processing_errors;
ANALYZE techbd_udi_ingress.sat_diagnostic_dataledger_api;
ANALYZE techbd_udi_ingress.sat_diagnostic_exception;
ANALYZE techbd_udi_ingress.sat_diagnostic_log;
ANALYZE techbd_udi_ingress.sat_expectation_http_request;
ANALYZE techbd_udi_ingress.sat_interaction_ccda_request;
ANALYZE techbd_udi_ingress.sat_interaction_ccda_validation_errors;
ANALYZE techbd_udi_ingress.sat_interaction_fhir_request;
ANALYZE techbd_udi_ingress.sat_interaction_fhir_screening_info;
