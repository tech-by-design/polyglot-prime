-- Purpose: Back fill the newly added 'tenant_id' columns from the master table tenants

/* Step 1. UPDATE tenant_id colum with tenants.tenant_id */

UPDATE techbd_udi_ingress.dashboard_widget_metadata t
SET tenant_id = tm.tenant_id
FROM techbd_udi_ingress.tenants tm
WHERE LOWER(TRIM(t.tenant_name)) = LOWER(TRIM(tm.tenant_name)) AND (t.tenant_id = '' OR t.tenant_id IS NULL);

/* After updating tenant_ids with master data values do..
 * 1. DROP the unique constraint
 * 2. Add new unique constraint on (widget_name, tenant_id)
 * 3. SET tenant_id  NOT NULL
 * 4. Update the function upsert_dashboard_widget_metadata with "ON CONFLICT (widget_name, tenant_id)"
 */
 
ALTER TABLE techbd_udi_ingress.dashboard_widget_metadata 
	DROP CONSTRAINT uq_dashboard_widget_tenant;
ALTER TABLE techbd_udi_ingress.dashboard_widget_metadata
	ADD CONSTRAINT uq_dashboard_widget_tenant
	UNIQUE (widget_name, tenant_id);
ALTER TABLE techbd_udi_ingress.dashboard_widget_metadata
	ALTER COLUMN tenant_id SET NOT NULL;

